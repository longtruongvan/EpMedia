<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lumina_bg">

    <!-- Top AppBar Header -->
    <RelativeLayout
        android:id="@+id/header_layout"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:paddingHorizontal="16dp"
        android:background="@color/lumina_surface">

        <!-- Back button (Left aligned) -->
        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            app:tint="@color/lumina_text_primary"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true" />

        <!-- Center Title "Editor" (Centered on screen) -->
        <TextView
            android:id="@+id/header_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/editor"
            android:textColor="@color/lumina_text_primary"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_centerInParent="true" />

        <!-- Right Text Button "Export" (Right aligned) -->
        <TextView
            android:id="@+id/btn_export_action"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/export"
            android:textColor="@color/colorAccent"
            android:textSize="15sp"
            android:textStyle="bold"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true" />

        <!-- Bottom Border Line (1px) -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#1AFFFFFF"
            android:layout_alignParentBottom="true" />
    </RelativeLayout>

    <!-- Main Content Body -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_marginTop="56dp"
        android:layout_marginBottom="60dp"
        android:padding="16dp">

        <!-- Video Preview Thumbnail Card -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="@drawable/bg_track_clip"
            android:backgroundTint="@color/lumina_surface"
            android:layout_marginBottom="20dp">

            <ImageView
                android:id="@+id/iv_export_preview"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_gallery"
                android:alpha="0.3" />

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#2000C2FF" />

            <!-- Subtitles overlays -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="bottom|start"
                android:layout_margin="12dp">

                <TextView
                    android:id="@+id/tv_export_res_tag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="1080p"
                    android:textColor="@color/lumina_bg"
                    android:backgroundTint="@color/colorAccent"
                    android:background="@drawable/bg_playhead_dot"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp" />

                <TextView
                    android:id="@+id/tv_export_duration_tag"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="00:45"
                    android:textColor="#FFFFFF"
                    android:background="#B31C1B1C"
                    android:textSize="10sp"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="2dp"
                    android:layout_marginStart="8dp" />
            </LinearLayout>
        </FrameLayout>

        <!-- Progress Section -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="24dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="bottom">
                <TextView
                    android:id="@+id/tv_export_status"
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:text="@string/ready_to_export"
                    android:textColor="@color/lumina_text_primary"
                    android:textSize="16sp"
                    android:textStyle="bold" />
                <TextView
                    android:id="@+id/tv_export_percent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textColor="@color/colorAccent"
                    android:textSize="15sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <ProgressBar
                android:id="@+id/progress_export"
                style="?android:attr/progressBarStyleHorizontal"
                android:layout_width="match_parent"
                android:layout_height="6dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="4dp"
                android:progressDrawable="@android:drawable/progress_horizontal"
                android:progressTint="@color/colorAccent"
                android:progressBackgroundTint="#20FFFFFF"
                android:max="100"
                android:progress="0" />

            <TextView
                android:id="@+id/tv_estimated_size"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Estimated file size: -- MB"
                android:textColor="@color/lumina_text_secondary"
                android:textSize="10sp"
                android:gravity="end" />
        </LinearLayout>

        <!-- Configuration selectors (Resolution / FPS) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_track_clip"
            android:backgroundTint="@color/lumina_surface"
            android:padding="12dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/resolution"
                android:textColor="@color/lumina_text_secondary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/btn_res_720p"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="720p"
                    android:textSize="11sp"
                    android:textColor="@color/lumina_text_primary"
                    android:backgroundTint="@color/lumina_surface_container"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="6dp"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/btn_res_1080p"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="1080p"
                    android:textSize="11sp"
                    android:textColor="@color/lumina_bg"
                    android:backgroundTint="@color/colorAccent"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="6dp"
                    android:layout_marginHorizontal="2dp" />

                <Button
                    android:id="@+id/btn_res_2k"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="2K"
                    android:textSize="11sp"
                    android:textColor="@color/lumina_text_primary"
                    android:backgroundTint="@color/lumina_surface_container"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="6dp"
                    android:layout_marginHorizontal="2dp" />

                <Button
                    android:id="@+id/btn_res_4k"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="4K"
                    android:textSize="11sp"
                    android:textColor="@color/lumina_text_primary"
                    android:backgroundTint="@color/lumina_surface_container"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="6dp"
                    android:layout_marginStart="4dp" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/frame_rate"
                android:textColor="@color/lumina_text_secondary"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btn_fps_24"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="24"
                    android:textSize="11sp"
                    android:textColor="@color/lumina_text_primary"
                    android:backgroundTint="@color/lumina_surface_container"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="6dp"
                    android:layout_marginEnd="4dp" />

                <Button
                    android:id="@+id/btn_fps_30"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="30"
                    android:textSize="11sp"
                    android:textColor="@color/lumina_bg"
                    android:backgroundTint="@color/colorAccent"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="6dp"
                    android:layout_marginHorizontal="2dp" />

                <Button
                    android:id="@+id/btn_fps_60"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="60"
                    android:textSize="11sp"
                    android:textColor="@color/lumina_text_primary"
                    android:backgroundTint="@color/lumina_surface_container"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="6dp"
                    android:layout_marginStart="4dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Social Quick Share -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/share_to"
            android:textColor="@color/lumina_text_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="3"
            android:layout_marginBottom="16dp">

            <!-- Instagram -->
            <LinearLayout
                android:id="@+id/btn_share_instagram"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="76dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_track_clip"
                android:backgroundTint="@color/lumina_surface"
                android:layout_marginEnd="6dp"
                android:clickable="true"
                android:focusable="true">
                <FrameLayout
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_circle_play"
                    android:backgroundTint="#FFE1306C">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_enhance"
                        app:tint="#FFFFFF"
                        android:layout_gravity="center" />
                </FrameLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Instagram"
                    android:textColor="@color/lumina_text_primary"
                    android:textSize="10sp"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <!-- TikTok -->
            <LinearLayout
                android:id="@+id/btn_share_tiktok"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="76dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_track_clip"
                android:backgroundTint="@color/lumina_surface"
                android:layout_marginHorizontal="2dp"
                android:clickable="true"
                android:focusable="true">
                <FrameLayout
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_circle_play"
                    android:backgroundTint="#FF010101">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_audio"
                        app:tint="#FFFFFF"
                        android:layout_gravity="center" />
                </FrameLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TikTok"
                    android:textColor="@color/lumina_text_primary"
                    android:textSize="10sp"
                    android:layout_marginTop="6dp" />
            </LinearLayout>

            <!-- YouTube -->
            <LinearLayout
                android:id="@+id/btn_share_youtube"
                android:layout_width="0dp"
                android:layout_columnWeight="1"
                android:layout_height="76dp"
                android:orientation="vertical"
                android:gravity="center"
                android:background="@drawable/bg_track_clip"
                android:backgroundTint="@color/lumina_surface"
                android:layout_marginStart="6dp"
                android:clickable="true"
                android:focusable="true">
                <FrameLayout
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:background="@drawable/bg_circle_play"
                    android:backgroundTint="#FFFF0000">
                    <ImageView
                        android:layout_width="16dp"
                        android:layout_height="16dp"
                        android:src="@drawable/ic_play"
                        app:tint="#FFFFFF"
                        android:layout_gravity="center" />
                </FrameLayout>
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="YouTube"
                    android:textColor="@color/lumina_text_primary"
                    android:textSize="10sp"
                    android:layout_marginTop="6dp" />
            </LinearLayout>
        </GridLayout>

        <!-- Big Trigger Export Button -->
        <Button
            android:id="@+id/btn_trigger_export"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:backgroundTint="@color/colorAccent"
            android:textColor="@color/lumina_bg"
            android:text="@string/export"
            android:textSize="14sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            android:elevation="4dp" />
    </LinearLayout>

    <!-- Top Divider line for bottom tabs -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="60dp"
        android:background="#1AFFFFFF" />

    <!-- Bottom Navigation Bar (Home, Templates, AI, Projects, Profile) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:background="@color/lumina_surface"
        android:elevation="8dp">

        <LinearLayout
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_home"
                app:tint="@color/lumina_text_secondary" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home"
                android:textColor="@color/lumina_text_secondary"
                android:textSize="10sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_templates"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_templates"
                app:tint="@color/lumina_text_secondary" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/templates"
                android:textColor="@color/lumina_text_secondary"
                android:textSize="10sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_projects"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_layers"
                app:tint="@color/colorAccent" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/projects"
                android:textColor="@color/colorAccent"
                android:textSize="10sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_ai"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_ai"
                app:tint="@color/lumina_text_secondary" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ai"
                android:textColor="@color/lumina_text_secondary"
                android:textSize="10sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_profile"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_profile"
                app:tint="@color/lumina_text_secondary" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile"
                android:textColor="@color/lumina_text_secondary"
                android:textSize="10sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
