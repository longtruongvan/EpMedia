<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/capcut_bg"
    android:orientation="vertical">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:orientation="horizontal">
        
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Workspace"
            android:textColor="@color/capcut_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/bt_exec"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:backgroundTint="@color/colorAccent"
            android:textColor="@color/capcut_bg"
            android:text="Export"
            android:textSize="14sp"
            android:paddingHorizontal="16dp"
            app:cornerRadius="18dp" />
    </LinearLayout>

    <!-- Video Preview -->
    <FrameLayout
        android:id="@+id/video_container"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:layout_margin="16dp"
        android:background="#000000">
        
        <VideoView
            android:id="@+id/video_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center" />
            
        <TextView
            android:id="@+id/tv_subtitle_preview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:textColor="#FFFFFF"
            android:textSize="18sp"
            android:shadowColor="#000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="2"
            android:visibility="gone"
            android:text="Subtitle Preview" />

        <ImageView
            android:id="@+id/iv_play_pause"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:src="@android:drawable/ic_media_play"
            app:tint="#80FFFFFF"
            android:visibility="visible" />
            
        <TextView
            android:id="@+id/tv_file"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="16dp"
            android:text="@string/please_select_file"
            android:textColor="@color/capcut_text_secondary"
            android:textSize="12sp" />
    </FrameLayout>

    <Button
        android:id="@+id/bt_file"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:text="@string/btn_add_video"
        android:backgroundTint="@color/capcut_surface"
        android:textColor="@color/capcut_text_primary" />

    <!-- Timeline Layout -->
    <LinearLayout
        android:id="@+id/layout_timeline"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="8dp"
        android:padding="8dp"
        android:background="@color/capcut_surface"
        android:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Timeline"
            android:textColor="@color/capcut_text_primary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginBottom="8dp" />

        <HorizontalScrollView
            android:id="@+id/timeline_scroll"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:scrollbars="none"
            android:background="#1A1A1A">
            
            <LinearLayout
                android:id="@+id/timeline_thumbnails"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:orientation="horizontal" />
        </HorizontalScrollView>

        <com.google.android.material.slider.RangeSlider
            android:id="@+id/range_slider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:valueFrom="0"
            android:valueTo="100"
            app:values="@array/initial_range_values"
            app:haloColor="@color/colorAccent"
            app:thumbColor="@color/colorAccent"
            app:trackColorActive="@color/colorAccent"
            app:trackColorInactive="#40FFFFFF" />
            
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">
            
            <TextView
                android:id="@+id/tv_trim_start"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Start: 0.0s"
                android:textColor="@color/capcut_text_secondary"
                android:textSize="12sp" />
                
            <Space
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />
                
            <TextView
                android:id="@+id/tv_trim_duration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Duration: 0.0s"
                android:textColor="@color/colorAccent"
                android:textSize="12sp"
                android:textStyle="bold" />

            <Space
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1" />

            <TextView
                android:id="@+id/tv_trim_end"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="End: 0.0s"
                android:textColor="@color/capcut_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- 剪辑 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/capcut_surface"
                app:cardCornerRadius="8dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">
                    
                    <CheckBox
                        android:id="@+id/cb_clip"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/clip_video"
                        android:textColor="@color/capcut_text_primary" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">
                        
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/capcut_text_secondary"
                            android:text="@string/from_text"/>
                        <EditText
                            android:id="@+id/et_clip_start"
                            android:layout_width="60dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:textColor="@color/capcut_text_primary"
                            android:inputType="numberDecimal"
                            android:text="0"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/capcut_text_secondary"
                            android:text="@string/sec_to"/>
                        <EditText
                            android:id="@+id/et_clip_end"
                            android:layout_width="60dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:textColor="@color/capcut_text_primary"
                            android:inputType="numberDecimal"
                            android:text="5"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/capcut_text_secondary"
                            android:text="@string/sec_text"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 裁剪 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/capcut_surface"
                app:cardCornerRadius="8dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <CheckBox
                        android:id="@+id/cb_crop"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/crop_video"
                        android:textColor="@color/capcut_text_primary"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/capcut_text_secondary"
                            android:text="@string/start_x"/>
                        <EditText
                            android:id="@+id/et_crop_x"
                            android:layout_width="60dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:textColor="@color/capcut_text_primary"
                            android:inputType="number"
                            android:text="0"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/capcut_text_secondary"
                            android:text="@string/start_y"/>
                        <EditText
                            android:id="@+id/et_crop_y"
                            android:layout_width="60dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:textColor="@color/capcut_text_primary"
                            android:inputType="number"
                            android:text="0"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/capcut_text_secondary"
                            android:text="@string/crop_width"/>
                        <EditText
                            android:id="@+id/et_crop_w"
                            android:layout_width="60dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:textColor="@color/capcut_text_primary"
                            android:inputType="number"
                            android:text="200"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/capcut_text_secondary"
                            android:text="@string/crop_height"/>
                        <EditText
                            android:id="@+id/et_crop_h"
                            android:layout_width="60dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:textColor="@color/capcut_text_primary"
                            android:inputType="number"
                            android:text="200"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 旋转&镜像 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/capcut_surface"
                app:cardCornerRadius="8dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">
                        <CheckBox
                            android:id="@+id/cb_rotation"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="@string/rotate_video"
                            android:textColor="@color/capcut_text_primary"/>
                        <CheckBox
                            android:id="@+id/cb_mirror"
                            android:layout_width="0dp"
                            android:layout_weight="1"
                            android:layout_height="wrap_content"
                            android:text="@string/mirror_video"
                            android:textColor="@color/capcut_text_primary"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/capcut_text_secondary"
                            android:text="@string/rotation_angle"/>
                        <EditText
                            android:id="@+id/et_rotation"
                            android:layout_width="60dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:textColor="@color/capcut_text_primary"
                            android:inputType="number"
                            android:text="90"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- 字幕 -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="@color/capcut_surface"
                app:cardCornerRadius="8dp">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <CheckBox
                        android:id="@+id/cb_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/add_subtitle"
                        android:textColor="@color/capcut_text_primary"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/capcut_text_secondary"
                            android:text="@string/subtitle_x"/>
                        <EditText
                            android:id="@+id/et_text_x"
                            android:layout_width="60dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:textColor="@color/capcut_text_primary"
                            android:inputType="number"
                            android:text="50"/>
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/capcut_text_secondary"
                            android:text="@string/start_y"/>
                        <EditText
                            android:id="@+id/et_text_y"
                            android:layout_width="60dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:textColor="@color/capcut_text_primary"
                            android:inputType="number"
                            android:text="50"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/capcut_text_secondary"
                            android:text="@string/subtitle_content"/>
                        <EditText
                            android:id="@+id/et_text"
                            android:layout_width="130dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:textColor="@color/capcut_text_primary"
                            android:text="@string/default_subtitle"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            
            <Space
                android:layout_width="match_parent"
                android:layout_height="60dp" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>
