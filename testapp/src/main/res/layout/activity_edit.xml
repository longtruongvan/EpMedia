<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/capcut_bg"
    android:orientation="vertical">

    <!-- Top Bar -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:orientation="horizontal"
        android:background="@color/capcut_surface">
        
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Workspace"
            android:textColor="@color/capcut_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/bt_exec"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:backgroundTint="@color/colorAccent"
            android:textColor="@color/capcut_bg"
            android:text="Export"
            android:textSize="14sp"
            android:paddingHorizontal="16dp"
            app:cornerRadius="18dp" />
    </LinearLayout>

    <!-- Video Preview Frame -->
    <FrameLayout
        android:id="@+id/video_container"
        android:layout_width="match_parent"
        android:layout_height="240dp"
        android:layout_margin="16dp"
        android:background="#050505"
        android:clickable="true"
        android:focusable="true">
        
        <VideoView
            android:id="@+id/video_view"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:visibility="gone" />

        <!-- Subtitle overlay -->
        <TextView
            android:id="@+id/tv_subtitle_preview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal|bottom"
            android:layout_marginBottom="30dp"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:background="#80000000"
            android:paddingHorizontal="8dp"
            android:paddingVertical="4dp"
            android:visibility="gone"
            android:text="Subtitle Preview" />

        <!-- Play/Pause Button overlay -->
        <ImageView
            android:id="@+id/iv_play_pause"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_play"
            app:tint="#80FFFFFF"
            android:visibility="gone" />

        <!-- Import overlay / Empty State -->
        <LinearLayout
            android:id="@+id/video_empty_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:background="#1A1A1A">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="+"
                android:textColor="@color/colorAccent"
                android:textSize="36sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_file"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/please_select_file"
                android:textColor="@color/capcut_text_secondary"
                android:textSize="12sp" />
        </LinearLayout>
    </FrameLayout>

    <!-- Select video secondary button -->
    <Button
        android:id="@+id/bt_file"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="8dp"
        android:text="@string/btn_add_video"
        android:backgroundTint="@color/capcut_surface"
        android:textColor="@color/capcut_text_primary" />

    <!-- Dynamic Panel Container -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/capcut_bg">

        <!-- Onboarding Panel (Shown when no video loaded) -->
        <LinearLayout
            android:id="@+id/panel_onboarding"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="24dp"
            android:visibility="visible">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📽️"
                android:textSize="48sp"
                android:layout_marginBottom="16dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chọn video để bắt đầu"
                android:textColor="@color/capcut_text_primary"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hãy nhấn vào vùng phát ở trên hoặc nút 'Thêm Video' bên dưới để bắt đầu hành trình sáng tạo của bạn!"
                android:textColor="@color/capcut_text_secondary"
                android:textSize="13sp"
                android:gravity="center" />
        </LinearLayout>

        <!-- Panels Container (Shown only when video is loaded) -->
        <FrameLayout
            android:id="@+id/layout_panels"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone">

            <!-- Panel Trim -->
            <LinearLayout
                android:id="@+id/panel_trim"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="CẮT GHÉP VIDEO (TRIM)"
                    android:textColor="@color/colorAccent"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <HorizontalScrollView
                    android:id="@+id/timeline_scroll"
                    android:layout_width="match_parent"
                    android:layout_height="60dp"
                    android:scrollbars="none"
                    android:background="#1A1A1A">
                    <LinearLayout
                        android:id="@+id/timeline_thumbnails"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:orientation="horizontal" />
                </HorizontalScrollView>

                <com.google.android.material.slider.RangeSlider
                    android:id="@+id/range_slider"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="0"
                    android:valueTo="100"
                    app:values="@array/initial_range_values"
                    app:haloColor="@color/colorAccent"
                    app:thumbColor="@color/colorAccent"
                    app:trackColorActive="@color/colorAccent"
                    app:trackColorInactive="#40FFFFFF" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="4dp">
                    <TextView
                        android:id="@+id/tv_trim_start"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Bắt đầu: 0.0s"
                        android:textColor="@color/capcut_text_secondary"
                        android:textSize="12sp" />
                    <Space
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />
                    <TextView
                        android:id="@+id/tv_trim_duration"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Thời lượng: 0.0s"
                        android:textColor="@color/colorAccent"
                        android:textSize="12sp"
                        android:textStyle="bold" />
                    <Space
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />
                    <TextView
                        android:id="@+id/tv_trim_end"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Kết thúc: 0.0s"
                        android:textColor="@color/capcut_text_secondary"
                        android:textSize="12sp" />
                </LinearLayout>
            </LinearLayout>

            <!-- Panel Canvas -->
            <LinearLayout
                android:id="@+id/panel_canvas"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="KHUNG HÌNH (CANVAS)"
                    android:textColor="@color/colorAccent"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <!-- Quick Transformations -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center"
                    android:layout_marginBottom="16dp">

                    <Button
                        android:id="@+id/btn_rotate_90"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Xoay +90°"
                        android:textSize="12sp"
                        android:layout_marginEnd="8dp"
                        android:backgroundTint="@color/capcut_surface"
                        android:textColor="@color/capcut_text_primary"
                        app:cornerRadius="8dp"/>

                    <Button
                        android:id="@+id/btn_mirror"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Lật Gương"
                        android:textSize="12sp"
                        android:layout_marginStart="8dp"
                        android:backgroundTint="@color/capcut_surface"
                        android:textColor="@color/capcut_text_primary"
                        app:cornerRadius="8dp"/>
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tỉ lệ khung hình (Crop Presets)"
                    android:textColor="@color/capcut_text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="8dp"/>

                <!-- Crop presets -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center">

                    <Button
                        android:id="@+id/btn_crop_original"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="Gốc"
                        android:textSize="11sp"
                        android:layout_marginEnd="4dp"
                        android:backgroundTint="@color/colorAccent"
                        android:textColor="@color/capcut_bg"
                        app:cornerRadius="4dp"/>

                    <Button
                        android:id="@+id/btn_crop_16_9"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="16:9"
                        android:textSize="11sp"
                        android:layout_marginHorizontal="4dp"
                        android:backgroundTint="@color/capcut_surface"
                        android:textColor="@color/capcut_text_primary"
                        app:cornerRadius="4dp"/>

                    <Button
                        android:id="@+id/btn_crop_9_16"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="9:16"
                        android:textSize="11sp"
                        android:layout_marginHorizontal="4dp"
                        android:backgroundTint="@color/capcut_surface"
                        android:textColor="@color/capcut_text_primary"
                        app:cornerRadius="4dp"/>

                    <Button
                        android:id="@+id/btn_crop_1_1"
                        android:layout_width="0dp"
                        android:layout_weight="1"
                        android:layout_height="wrap_content"
                        android:text="1:1"
                        android:textSize="11sp"
                        android:layout_marginStart="4dp"
                        android:backgroundTint="@color/capcut_surface"
                        android:textColor="@color/capcut_text_primary"
                        app:cornerRadius="4dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Panel Text -->
            <LinearLayout
                android:id="@+id/panel_text"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical"
                android:padding="16dp"
                android:visibility="gone">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="THÊM CHỮ / PHỤ ĐỀ (TEXT)"
                    android:textColor="@color/colorAccent"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp"/>

                <EditText
                    android:id="@+id/et_subtitle_input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Nhập nội dung phụ đề..."
                    android:textColorHint="@color/capcut_text_secondary"
                    android:textColor="@color/capcut_text_primary"
                    android:backgroundTint="@color/colorAccent"
                    android:textSize="14sp"
                    android:layout_marginBottom="16dp"
                    android:maxLines="2" />

                <!-- Position Controls -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vị trí Ngang (X %)"
                    android:textColor="@color/capcut_text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>
                    
                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_text_x"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="0"
                    android:valueTo="100"
                    android:value="50"
                    app:thumbColor="@color/colorAccent"
                    app:trackColorActive="@color/colorAccent"
                    app:trackColorInactive="#40FFFFFF"
                    android:layout_marginBottom="12dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Vị trí Dọc (Y %)"
                    android:textColor="@color/capcut_text_secondary"
                    android:textSize="12sp"
                    android:layout_marginBottom="4dp"/>
                    
                <com.google.android.material.slider.Slider
                    android:id="@+id/slider_text_y"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:valueFrom="0"
                    android:valueTo="100"
                    android:value="85"
                    app:thumbColor="@color/colorAccent"
                    app:trackColorActive="@color/colorAccent"
                    app:trackColorInactive="#40FFFFFF" />
            </LinearLayout>

        </FrameLayout>
    </FrameLayout>

    <!-- Bottom Toolbar -->
    <LinearLayout
        android:id="@+id/bottom_toolbar"
        android:layout_width="match_parent"
        android:layout_height="65dp"
        android:orientation="horizontal"
        android:background="@color/capcut_surface"
        android:gravity="center_vertical">

        <LinearLayout
            android:id="@+id/tab_trim"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            
            <ImageView
                android:id="@+id/iv_tab_trim"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_trim"
                app:tint="@color/colorAccent" />
                
            <TextView
                android:id="@+id/tv_tab_trim"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cắt đoạn"
                android:textColor="@color/colorAccent"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tab_canvas"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            
            <ImageView
                android:id="@+id/iv_tab_canvas"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_canvas"
                app:tint="@color/capcut_text_secondary" />
                
            <TextView
                android:id="@+id/tv_tab_canvas"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Khung hình"
                android:textColor="@color/capcut_text_secondary"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/tab_text"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?attr/selectableItemBackground"
            android:clickable="true"
            android:focusable="true">
            
            <ImageView
                android:id="@+id/iv_tab_text"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_text"
                app:tint="@color/capcut_text_secondary" />
                
            <TextView
                android:id="@+id/tv_tab_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Văn bản"
                android:textColor="@color/capcut_text_secondary"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
