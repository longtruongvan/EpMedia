<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/lumina_bg">

    <!-- Top AppBar Header -->
    <LinearLayout
        android:id="@+id/header_layout"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="16dp"
        android:background="@color/lumina_surface"
        android:elevation="4dp">

        <ImageView
            android:id="@+id/btn_back"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:src="@drawable/ic_arrow_back"
            android:contentDescription="Back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true"
            app:tint="@color/lumina_text_primary" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:text="@string/media"
            android:textColor="@color/lumina_text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:layout_marginTop="56dp"
        android:layout_marginBottom="60dp">

        <!-- Search Bar & Filters -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:paddingVertical="12dp"
            android:background="@color/lumina_bg">

            <!-- Search box -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:background="@drawable/bg_track_clip"
                android:backgroundTint="@color/lumina_surface"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:src="@drawable/ic_search"
                    app:tint="@color/lumina_text_secondary" />

                <EditText
                    android:id="@+id/et_search"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:hint="@string/search_media_hint"
                    android:textColorHint="@color/lumina_text_secondary"
                    android:textColor="@color/lumina_text_primary"
                    android:background="@null"
                    android:textSize="13sp"
                    android:layout_marginStart="8dp"
                    android:singleLine="true" />
            </LinearLayout>

            <!-- Segmented Control Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:background="@drawable/bg_track_clip"
                android:backgroundTint="@color/lumina_surface"
                android:orientation="horizontal"
                android:padding="2dp">

                <Button
                    android:id="@+id/btn_seg_recent"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="@string/seg_recent"
                    android:textSize="11sp"
                    android:textColor="@color/lumina_bg"
                    android:backgroundTint="@color/colorAccent"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="6dp"
                    style="?android:attr/borderlessButtonStyle" />

                <Button
                    android:id="@+id/btn_seg_videos"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="@string/seg_videos"
                    android:textSize="11sp"
                    android:textColor="@color/lumina_text_secondary"
                    android:backgroundTint="@android:color/transparent"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="6dp"
                    style="?android:attr/borderlessButtonStyle" />

                <Button
                    android:id="@+id/btn_seg_photos"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:text="@string/seg_photos"
                    android:textSize="11sp"
                    android:textColor="@color/lumina_text_secondary"
                    android:backgroundTint="@android:color/transparent"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:cornerRadius="6dp"
                    style="?android:attr/borderlessButtonStyle" />
            </LinearLayout>
        </LinearLayout>

        <!-- Media Gallery Grid -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_media_grid"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:paddingHorizontal="1dp"
            android:scrollbars="vertical" />
    </LinearLayout>

    <!-- Floating Bottom Import Button (Only shown when items selected) -->
    <LinearLayout
        android:id="@+id/layout_import_action"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginBottom="72dp"
        android:paddingHorizontal="16dp"
        android:clickable="false"
        android:focusable="false"
        android:visibility="gone">

        <Button
            android:id="@+id/btn_import_submit"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:backgroundTint="@color/colorAccent"
            android:textColor="@color/lumina_bg"
            android:text="@string/btn_select_file"
            android:textSize="14sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            android:elevation="8dp" />
    </LinearLayout>

    <!-- Top Divider line for bottom tabs -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_gravity="bottom"
        android:layout_marginBottom="60dp"
        android:background="#1AFFFFFF" />

    <!-- Bottom Navigation Bar (Home, Templates, AI, Projects, Profile) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:background="@color/lumina_surface"
        android:elevation="8dp">

        <LinearLayout
            android:id="@+id/nav_home"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_history"
                app:tint="@color/lumina_text_secondary" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/home"
                android:textColor="@color/lumina_text_secondary"
                android:textSize="10sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_templates"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_effects"
                app:tint="@color/lumina_text_secondary" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/templates"
                android:textColor="@color/lumina_text_secondary"
                android:textSize="10sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_projects"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_layers"
                app:tint="@color/colorAccent" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/projects"
                android:textColor="@color/colorAccent"
                android:textSize="10sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_ai"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_enhance"
                app:tint="@color/lumina_text_secondary" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/ai"
                android:textColor="@color/lumina_text_secondary"
                android:textSize="10sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/nav_profile"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:clickable="true"
            android:focusable="true"
            android:background="?attr/selectableItemBackground">
            <ImageView
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_more"
                app:tint="@color/lumina_text_secondary" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/profile"
                android:textColor="@color/lumina_text_secondary"
                android:textSize="10sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
