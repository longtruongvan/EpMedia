<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="80dp"
    android:background="?android:attr/selectableItemBackground"
    android:paddingVertical="10dp">

    <!-- Album Art & Play State Overlay -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/layout_album_art"
        android:layout_width="60dp"
        android:layout_height="60dp"
        android:layout_centerVertical="true"
        android:layout_alignParentStart="true"
        app:cardCornerRadius="10dp"
        app:cardElevation="0dp"
        app:strokeWidth="0dp"
        app:cardBackgroundColor="#1AFFFFFF">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <!-- Programmatic Vibrant Gradient Background -->
            <ImageView
                android:id="@+id/iv_album_gradient"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop" />

            <!-- Audio Note Icon at 50% Opacity -->
            <ImageView
                android:id="@+id/iv_album_note"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_gravity="center"
                android:src="@drawable/ic_audio"
                android:alpha="0.5"
                app:tint="#FFFFFF" />

            <!-- Play/Pause & Loading State Overlay (Always clickable) -->
            <FrameLayout
                android:id="@+id/layout_play_state"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="#33000000"
                android:clickable="true"
                android:focusable="true">

                <ImageView
                    android:id="@+id/iv_track_play"
                    android:layout_width="22dp"
                    android:layout_height="22dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_play"
                    app:tint="#FFFFFF" />

                <ProgressBar
                    android:id="@+id/pb_track_loading"
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:visibility="gone"
                    android:indeterminateTint="@color/colorAccent"
                    style="?android:attr/progressBarStyleSmall"/>
            </FrameLayout>

        </FrameLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Track Metadata (Title, Artist, Category Badge) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_toEndOf="@id/layout_album_art"
        android:layout_toStartOf="@+id/btn_use_track"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_track_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Track Title"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:ellipsize="end"
            android:maxLines="1"/>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tv_track_artist"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Artist"
                android:textColor="#8E8E93"
                android:textSize="13sp"
                android:ellipsize="end"
                android:maxLines="1"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="  •  "
                android:textColor="#3A3A3C"
                android:textSize="13sp"/>

            <!-- Category capsule badge -->
            <TextView
                android:id="@+id/tv_track_category"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_category_pill"
                android:backgroundTint="#24FFFFFF"
                android:textColor="@color/colorAccent"
                android:textSize="10sp"
                android:textStyle="bold"
                android:text="Vlog"
                android:paddingHorizontal="8dp"
                android:paddingVertical="2dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Download & Use Action Button -->
    <ImageView
        android:id="@+id/btn_use_track"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:padding="10dp"
        android:src="@drawable/ic_download"
        app:tint="@color/colorAccent"
        android:background="?android:attr/selectableItemBackgroundBorderless"
        android:clickable="true"
        android:focusable="true"/>

    <!-- Bottom Divider Line -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_alignParentBottom="true"
        android:layout_toEndOf="@id/layout_album_art"
        android:layout_marginStart="16dp"
        android:background="#0AFFFFFF"/>

</RelativeLayout>
